@model List<SalaryManagement.Domain.Entities.ThuongPhat>

@{
    ViewData["Title"] = "Thưởng / Phạt";
}

@section TopbarActions {
    <a href="/ThuongPhat/ThemMoi" class="btn-gold btn">
        <i class="bi bi-plus-lg"></i> Thêm mới
    </a>
}

@if (TempData["Success"] != null)
{
    <div class="alert-success-dark">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="card-dark">
    <div class="card-header-dark">Danh sách thưởng / phạt</div>
    <div class="p-3">
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Nhân Viên</th>
                    <th class="text-center">Tháng/Năm</th>
                    <th>Loại</th>
                    <th>Mô Tả</th>
                    <th class="text-end">Số Tiền</th>
                    <th class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center" style="color:#6b7280; padding:40px">
                            <i class="bi bi-star" style="font-size:32px"></i>
                            <div class="mt-2">Chưa có dữ liệu thưởng/phạt.</div>
                        </td>
                    </tr>
                }
                @foreach (var tp in Model)
                {
                    <tr>
                        <td>@tp.NhanVien?.HoTen</td>
                        <td class="text-center">@tp.Thang/@tp.Nam</td>
                        <td>
                            @if (tp.Loai == SalaryManagement.Domain.Enums.LoaiThuongPhat.PhatViPham ||
                                                             tp.Loai == SalaryManagement.Domain.Enums.LoaiThuongPhat.KhauTruKhac)
                            {
                                <span class="badge-warning">Phạt</span>
                            }
                            else
                            {
                                <span class="badge-success">Thưởng</span>
                            }
                        </td>
                        <td style="color:#9ca3af">@tp.MoTa</td>
                        <td class="text-end">@tp.SoTien.ToString("N0") ₫</td>
                        <td class="text-center">
                            <form method="post" action="/ThuongPhat/Xoa" class="d-inline">
                                <input type="hidden" name="id" value="@tp.Id" />
                                <button class="btn btn-sm"
                                        style="background:#7f1d1d;color:#f87171;border:none;border-radius:6px"
                                        onclick="return confirm('Xóa bản ghi này?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>