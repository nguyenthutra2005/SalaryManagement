@model List<SalaryManagement.Application.DTOs.BangLuongDto>

@{
    ViewData["Title"] = "Xuất Excel / PDF";
    var thang = (int)ViewBag.Thang;
    var nam = (int)ViewBag.Nam;
}

@section TopbarActions {
    <form method="get" class="d-flex gap-2 align-items-center">
        <select name="thang" class="form-select-dark">
            @for (int i = 1; i <= 12; i++)
            {
                if (i == thang)
                {
                    @:
                    <option value="@i" selected>Tháng @i</option>
                }
                else
                {
                    @:
                    <option value="@i">Tháng @i</option>
                }
            }
        </select>
        <input type="number" name="nam" value="@nam" class="form-control-dark" style="width:90px" />
        <button type="submit" class="btn-outline-light-custom btn">Xem</button>
    </form>
    <a href="/BaoCao/XuatExcel?thang=@thang&nam=@nam" class="btn-gold btn">
        <i class="bi bi-file-earmark-excel"></i> Xuất CSV/Excel
    </a>
}

<div class="card-dark mb-3">
    <div class="card-header-dark">Xem Trước Dữ Liệu — Tháng @thang/@nam</div>
    <div class="p-3">
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Mã NV</th>
                    <th>Họ Tên</th>
                    <th>Phòng Ban</th>
                    <th class="text-end">Gross</th>
                    <th class="text-end">BHXH+BHYT+BHTN</th>
                    <th class="text-end">Thuế TNCN</th>
                    <th class="text-end">Net</th>
                    <th class="text-center">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center" style="color:#6b7280;padding:40px">Chưa có dữ liệu tháng này</td></tr>
                }
                @foreach (var bl in Model)
                {
                    <tr>
                        <td style="color:#f59e0b">@bl.MaNhanVien</td>
                        <td>@bl.HoTen</td>
                        <td style="color:#9ca3af">@bl.TenPhongBan</td>
                        <td class="text-end">@bl.TongThuNhap.ToString("N0") ₫</td>
                        <td class="text-end" style="color:#f87171">@((bl.BaoHiemXaHoi + bl.BaoHiemYTe + bl.BaoHiemThatNghiep).ToString("N0")) ₫</td>
                        <td class="text-end" style="color:#f87171">@bl.ThueThuNhapCaNhan.ToString("N0") ₫</td>
                        <td class="text-end" style="color:#34d399">@bl.ThuNhapRong.ToString("N0") ₫</td>
                        <td class="text-center">
                            @if (bl.TrangThai == "DaDuyet")
                            {
                                <span class="badge-success">Đã duyệt</span>
                            }
                            else
                            {
                                <span class="badge-secondary">Nháp</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
