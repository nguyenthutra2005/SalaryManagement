@model List<SalaryManagement.Domain.Entities.NhanVien>

@{
    ViewData["Title"] = "Nhân Viên";
}

@section TopbarActions {
    <a href="/NhanVien/ThemMoi" class="btn-gold btn">
        <i class="bi bi-person-plus"></i> Thêm nhân viên
    </a>
}

@if (TempData["Success"] != null)
{
    <div class="alert-success-dark">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="card-dark">
    <div class="card-header-dark d-flex justify-content-between align-items-center">
        <span>Danh sách nhân viên</span>
        <span style="color:#6b7280; font-size:13px">@Model.Count người</span>
    </div>
    <div class="p-3">
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Mã NV</th>
                    <th>Họ Tên</th>
                    <th>Phòng Ban</th>
                    <th>Chức Vụ</th>
                    <th class="text-end">Lương Cơ Bản</th>
                    <th class="text-center">Trạng Thái</th>
                    <th class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center" style="color:#6b7280; padding:40px">
                            <i class="bi bi-people" style="font-size:32px"></i>
                            <div class="mt-2">Chưa có nhân viên nào. Nhấn "Thêm nhân viên" để bắt đầu.</div>
                        </td>
                    </tr>
                }
                @foreach (var nv in Model)
                {
                    <tr>
                        <td style="color:#f59e0b">@nv.MaNhanVien</td>
                        <td>
                            <div>@nv.HoTen</div>
                            <div style="font-size:12px; color:#6b7280">@nv.Email</div>
                        </td>
                        <td style="color:#9ca3af">@nv.PhongBan?.TenPhongBan</td>
                        <td style="color:#9ca3af">@nv.ChucVu?.TenChucVu</td>
                        <td class="text-end">@(nv.CauHinhLuong?.LuongCoBan.ToString("N0") ?? "—") ₫</td>
                        <td class="text-center">
                            @if (nv.TrangThai == SalaryManagement.Domain.Enums.TrangThaiNhanVien.DangLamViec)
                            {
                                <span class="badge-success">Đang làm việc</span>
                            }
                            else
                            {
                                <span class="badge-secondary">Nghỉ việc</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a href="/NhanVien/ChinhSua/@nv.Id" class="btn btn-sm btn-outline-light-custom">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="/NhanVien/Xoa" class="d-inline">
                                    <input type="hidden" name="id" value="@nv.Id" />
                                    <button class="btn btn-sm"
                                            style="background:#7f1d1d;color:#f87171;border:none;border-radius:6px"
                                            onclick="return confirm('Xóa nhân viên @nv.HoTen?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>