@model SalaryManagement.Domain.Entities.NhanVien

@{
    ViewData["Title"] = "Thêm Nhân Viên";
}

@section TopbarActions {
    <a href="/NhanVien/Index" class="btn-outline-light-custom btn">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

@if (TempData["Error"] != null)
{
    <div style="background:#7f1d1d;color:#f87171;padding:12px;border-radius:8px;margin-bottom:16px">
        ❌ @TempData["Error"]
    </div>
}

<div style="max-width:700px">
    <div class="card-dark">
        <div class="card-header-dark">Thông Tin Nhân Viên</div>
        <div class="p-4">
            <form method="post" action="/NhanVien/ThemMoi">
                <input type="hidden" name="DaXoa" value="false" />
                <input type="hidden" name="LaCuTru" value="true" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Mã nhân viên *</label>
                        <input name="MaNhanVien" class="form-control-dark w-100 mt-1" required />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Họ tên *</label>
                        <input name="HoTen" class="form-control-dark w-100 mt-1" required />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Email</label>
                        <input name="Email" type="email" class="form-control-dark w-100 mt-1" />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Điện thoại</label>
                        <input name="DienThoai" class="form-control-dark w-100 mt-1" />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Ngày sinh *</label>
                        <input name="NgaySinh" type="date" class="form-control-dark w-100 mt-1" required />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Ngày vào làm *</label>
                        <input name="NgayVaoLam" type="date" class="form-control-dark w-100 mt-1" required />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Phòng ban *</label>
                        <select name="PhongBanId" class="form-select-dark w-100 mt-1" required>
                            <option value="">-- Chọn phòng ban --</option>
                            @foreach (var pb in ViewBag.PhongBans as List<SalaryManagement.Domain.Entities.PhongBan>)
                            {
                                <option value="@pb.Id">@pb.TenPhongBan</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Chức vụ *</label>
                        <select name="ChucVuId" class="form-select-dark w-100 mt-1" required>
                            <option value="">-- Chọn chức vụ --</option>
                            @foreach (var cv in ViewBag.ChucVus as List<SalaryManagement.Domain.Entities.ChucVu>)
                            {
                                <option value="@cv.Id">@cv.TenChucVu</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Vùng lương tối thiểu *</label>
                        <select name="Vung" class="form-select-dark w-100 mt-1" required>
                            <option value="1">Vùng I - 5.310.000đ (HCM, Hà Nội...)</option>
                            <option value="2">Vùng II - 4.730.000đ</option>
                            <option value="3">Vùng III - 4.140.000đ</option>
                            <option value="4">Vùng IV - 3.700.000đ</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Số người phụ thuộc</label>
                        <input name="SoNguoiPhuThuoc" type="number" value="0" min="0" class="form-control-dark w-100 mt-1" />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Lương cơ bản *</label>
                        <input name="luongCoBan" type="number" class="form-control-dark w-100 mt-1" required />
                    </div>
                    <div class="col-md-6">
                        <label style="color:#9ca3af;font-size:13px">Ngày công chuẩn</label>
                        <input name="soNgayCong" type="number" value="26" min="1" max="31" class="form-control-dark w-100 mt-1" />
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn-gold btn px-4">
                        <i class="bi bi-check-lg"></i> Lưu nhân viên
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>