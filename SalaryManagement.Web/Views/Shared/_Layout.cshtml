<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PayVN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #0f1117; color: #e2e8f0; display: flex; min-height: 100vh; }

        /* Sidebar */
        .sidebar { width: 260px; min-width: 260px; background: #1a1d2e; display: flex; flex-direction: column; padding: 24px 16px; border-right: 1px solid #2d3148; }
        .sidebar-brand { display: flex; align-items: center; gap: 12px; padding: 0 8px 24px; border-bottom: 1px solid #2d3148; margin-bottom: 24px; }
        .brand-icon { width: 40px; height: 40px; background: #f59e0b; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 18px; color: #1a1d2e; }
        .brand-text { line-height: 1.2; }
        .brand-text .name { font-weight: 700; font-size: 16px; color: #fff; }
        .brand-text .sub { font-size: 10px; color: #6b7280; letter-spacing: 1px; }

        .nav-section { font-size: 11px; color: #6b7280; letter-spacing: 1px; padding: 0 8px; margin: 16px 0 8px; }
        .nav-item a { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; color: #9ca3af; text-decoration: none; font-size: 14px; transition: all 0.2s; position: relative; }
        .nav-item a:hover { background: #2d3148; color: #fff; }
        .nav-item a.active { background: #2d3148; color: #fff; }
        .nav-item a.active::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 3px; height: 60%; background: #f59e0b; border-radius: 2px; }
        .badge-count { background: #ef4444; color: #fff; font-size: 11px; padding: 2px 7px; border-radius: 20px; margin-left: auto; }

        .user-card { margin-top: auto; padding: 12px; background: #2d3148; border-radius: 10px; display: flex; align-items: center; gap: 10px; }
        .user-avatar { width: 36px; height: 36px; background: #f59e0b; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: #1a1d2e; }
        .user-info .user-name { font-size: 13px; font-weight: 600; color: #fff; }
        .user-info .user-role { font-size: 11px; color: #6b7280; }

        /* Main */
        .main-wrapper { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .topbar { background: #1a1d2e; border-bottom: 1px solid #2d3148; padding: 12px 24px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .topbar-title { font-size: 18px; font-weight: 700; color: #fff; flex: 1; }
        .main-content { flex: 1; padding: 24px; overflow-y: auto; }

        /* Cards */
        .stat-card { background: #1a1d2e; border: 1px solid #2d3148; border-radius: 12px; padding: 20px; }
        .stat-card .label { font-size: 12px; color: #6b7280; margin-bottom: 8px; }
        .stat-card .value { font-size: 22px; font-weight: 700; }
        .stat-card .sub-value { font-size: 12px; color: #6b7280; margin-top: 4px; }

        .card-dark { background: #1a1d2e; border: 1px solid #2d3148; border-radius: 12px; }
        .card-dark .card-header-dark { padding: 16px 20px; border-bottom: 1px solid #2d3148; font-weight: 600; font-size: 15px; }

        /* Buttons */
        .btn-gold { background: #f59e0b; color: #1a1d2e; font-weight: 600; border: none; border-radius: 8px; padding: 8px 16px; }
        .btn-gold:hover { background: #d97706; color: #1a1d2e; }
        .btn-outline-light-custom { border: 1px solid #2d3148; color: #9ca3af; background: transparent; border-radius: 8px; padding: 8px 16px; }
        .btn-outline-light-custom:hover { background: #2d3148; color: #fff; }

        /* Table */
        .table-dark-custom { width: 100%; border-collapse: collapse; }
        .table-dark-custom th { background: #2d3148; color: #9ca3af; font-size: 12px; font-weight: 600; padding: 12px 16px; text-align: left; }
        .table-dark-custom td { padding: 12px 16px; border-bottom: 1px solid #2d3148; font-size: 14px; color: #e2e8f0; }
        .table-dark-custom tr:hover td { background: #2d3148; }

        /* Badge */
        .badge-success { background: #065f46; color: #34d399; padding: 4px 10px; border-radius: 20px; font-size: 12px; }
        .badge-warning { background: #78350f; color: #fbbf24; padding: 4px 10px; border-radius: 20px; font-size: 12px; }
        .badge-secondary { background: #374151; color: #9ca3af; padding: 4px 10px; border-radius: 20px; font-size: 12px; }

        /* Alert */
        .alert-success-dark { background: #065f46; border: 1px solid #34d399; color: #34d399; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; }

        /* Form controls dark */
        .form-control-dark, .form-select-dark {
            background: #2d3148; border: 1px solid #3d4468; color: #e2e8f0; border-radius: 8px; padding: 8px 12px;
        }
        .form-control-dark:focus, .form-select-dark:focus { background: #2d3148; border-color: #f59e0b; color: #e2e8f0; box-shadow: none; outline: none; }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">P</div>
            <div class="brand-text">
                <div class="name">PayVN</div>
                <div class="sub">HỆ THỐNG QUẢN LÝ LƯƠNG</div>
            </div>
        </div>

        <div class="nav-section">TỔNG QUAN</div>
        <div class="nav-item">
            <a href="/BangLuong/Dashboard" class="@(Context.Request.Path.Value?.Contains("Dashboard") == true ? "active" : "")">
                <i class="bi bi-grid"></i> Dashboard
            </a>
        </div>

        <div class="nav-section">NHÂN SỰ</div>
        <div class="nav-item">
            <a href="/NhanVien/Index" class="@(Context.Request.Path.Value?.Contains("NhanVien") == true ? "active" : "")">
                <i class="bi bi-people"></i> Nhân viên
            </a>
        </div>
        <div class="nav-item">
            <a href="/ChamCong/Index" class="@(Context.Request.Path.Value?.Contains("ChamCong") == true ? "active" : "")">
                <i class="bi bi-calendar-check"></i> Chấm công
            </a>
        </div>

        <div class="nav-section">LƯƠNG & THU NHẬP</div>
        <div class="nav-item">
            <a href="/BangLuong/Index" class="@(Context.Request.Path.Value?.Contains("BangLuong/Index") == true ? "active" : "")">
                <i class="bi bi-receipt"></i> Bảng lương
            </a>
        </div>
        <div class="nav-item">
            <a href="/ThuongPhat/Index" class="@(Context.Request.Path.Value?.Contains("ThuongPhat") == true ? "active" : "")">
                <i class="bi bi-star"></i> Thưởng / Phạt
            </a>
        </div>
        <div class="nav-item">
            <a href="/BangLuong/TinhThue" class="@(Context.Request.Path.Value?.Contains("TinhThue") == true ? "active" : "")">
                <i class="bi bi-calculator"></i> Tính thuế TNCN
            </a>
        </div>

        <div class="nav-section">BÁO CÁO</div>
        <div class="nav-item">
            <a href="/BaoCao/Index" class="@(Context.Request.Path.Value?.Contains("BaoCao") == true ? "active" : "")">
                <i class="bi bi-bar-chart"></i> Phân tích chi phí
            </a>
        </div>
        <div class="nav-item">
            <a href="/BaoCao/XuatFile" class="@(Context.Request.Path.Value?.Contains("XuatFile") == true ? "active" : "")">
                <i class="bi bi-download"></i> Xuất Excel / PDF
            </a>
        </div>

        <div class="user-card">
            <div class="user-avatar">
                @(Context.Session.GetString("VaiTro") == "Admin" ? "AD" : "NV")
            </div>
            <div class="user-info">
                <div class="user-name">@(Context.Session.GetString("TenDangNhap") ?? "Admin")</div>
                <div class="user-role">@(Context.Session.GetString("VaiTro") ?? "HR Manager")</div>
            </div>
            <a href="/TaiKhoan/DangXuat" style="color:#6b7280;margin-left:auto" title="Đăng xuất">
                <i class="bi bi-box-arrow-right" style="font-size:18px"></i>
            </a>
        </div>
    </div>

    <!-- Main -->
    <div class="main-wrapper">
        <div class="topbar">
            <div class="topbar-title">@ViewData["Title"]</div>
            @await RenderSectionAsync("TopbarActions", required: false)
        </div>
        <div class="main-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>