@model List<SalaryManagement.Domain.Entities.ChamCong>

@{
    ViewData["Title"] = "Chấm Công";
    var thang = (int)ViewBag.Thang;
    var nam = (int)ViewBag.Nam;
}

@section TopbarActions {
    <form method="get" class="d-flex gap-2 align-items-center">
        <select name="thang" class="form-select-dark">
            @for (int i = 1; i <= 12; i++)
            {
                if (i == thang)
                {
                    @:
                    <option value="@i" selected>Tháng @i</option>
                }
                else
                {
                    @:
                    <option value="@i">Tháng @i</option>
                }
            }
        </select>
        <input type="number" name="nam" value="@nam" class="form-control-dark" style="width:90px" />
        <button type="submit" class="btn-outline-light-custom btn">Xem</button>
    </form>
    <a href="/ChamCong/NhapChamCong?thang=@thang&nam=@nam" class="btn-gold btn">
        <i class="bi bi-pencil-square"></i> Nhập chấm công
    </a>
}

@if (TempData["Success"] != null)
{
    <div class="alert-success-dark">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="card-dark">
    <div class="card-header-dark d-flex justify-content-between">
        <span>Bảng Chấm Công Tháng @thang/@nam</span>
        <span style="color:#6b7280;font-size:13px">@Model.Count nhân viên</span>
    </div>
    <div class="p-3">
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Họ Tên</th>
                    <th>Phòng Ban</th>
                    <th class="text-center">Ngày Làm Việc</th>
                    <th class="text-center">Ngày Nghỉ</th>
                    <th class="text-center">Giờ Tăng Ca</th>
                    <th>Ghi Chú</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center" style="color:#6b7280;padding:40px">
                            <i class="bi bi-calendar-x" style="font-size:32px"></i>
                            <div class="mt-2">Chưa có dữ liệu chấm công. Nhấn "Nhập chấm công" để bắt đầu.</div>
                        </td>
                    </tr>
                }
                @foreach (var cc in Model)
                {
                    <tr>
                        <td>@cc.NhanVien?.HoTen</td>
                        <td style="color:#9ca3af">@cc.NhanVien?.PhongBan?.TenPhongBan</td>
                        <td class="text-center" style="color:#34d399">@cc.SoNgayLamViec</td>
                        <td class="text-center" style="color:#f87171">@cc.SoNgayNghi</td>
                        <td class="text-center" style="color:#f59e0b">@cc.SoGioTangCa</td>
                        <td style="color:#6b7280">@cc.GhiChu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>