@model SalaryManagement.Application.DTOs.BangLuongDto

@{
    ViewData["Title"] = "Phiếu Lương";
}

@section TopbarActions {
    <a href="/BangLuong/Index?thang=@Model.Thang&nam=@Model.Nam" class="btn-outline-light-custom btn">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
    @if (Model.TrangThai != "DaDuyet")
    {
        <form method="post" action="/BangLuong/Duyet" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="thang" value="@Model.Thang" />
            <input type="hidden" name="nam" value="@Model.Nam" />
            <button class="btn-gold btn">
                <i class="bi bi-check-circle"></i> Duyệt bảng lương
            </button>
        </form>
    }
}

<div class="row g-3">
    <!-- Cột trái -->
    <div class="col-md-5">
        <!-- Thông tin nhân viên -->
        <div class="card-dark mb-3">
            <div class="card-header-dark">Thông Tin Nhân Viên</div>
            <div class="p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div style="width:56px;height:56px;background:#f59e0b;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#1a1d2e">
                        @Model.HoTen.Substring(0, 1)
                    </div>
                    <div>
                        <div style="font-size:16px;font-weight:700;color:#fff">@Model.HoTen</div>
                        <div style="color:#6b7280;font-size:13px">@Model.TenChucVu</div>
                    </div>
                </div>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between">
                        <span style="color:#6b7280">Mã nhân viên</span>
                        <span style="color:#f59e0b">@Model.MaNhanVien</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#6b7280">Phòng ban</span>
                        <span>@Model.TenPhongBan</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#6b7280">Kỳ lương</span>
                        <span>Tháng @Model.Thang/@Model.Nam</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#6b7280">Ngày công</span>
                        <span>@Model.SoNgayCongThucTe ngày</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#6b7280">Trạng thái</span>
                        @if (Model.TrangThai == "DaDuyet")
                        {
                            <span class="badge-success">Đã duyệt</span>
                        }
                        else if (Model.TrangThai == "ChoDuyet")
                        {
                            <span class="badge-warning">Chờ duyệt</span>
                        }
                        else
                        {
                            <span class="badge-secondary">Nháp</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Lương thực nhận -->
        <div class="card-dark" style="border-color:#f59e0b">
            <div class="p-4 text-center">
                <div style="color:#6b7280; font-size:13px; margin-bottom:8px">💰 Lương Thực Nhận (Net)</div>
                <div style="font-size:32px; font-weight:800; color:#f59e0b">
                    @Model.ThuNhapRong.ToString("N0") ₫
                </div>
                <div style="color:#6b7280; font-size:12px; margin-top:8px">
                    Gross: @Model.TongThuNhap.ToString("N0") ₫
                </div>
            </div>
        </div>
    </div>

    <!-- Cột phải -->
    <div class="col-md-7">
        <!-- Thu nhập -->
        <div class="card-dark mb-3">
            <div class="card-header-dark" style="color:#34d399">
                <i class="bi bi-plus-circle"></i> Thu Nhập
            </div>
            <div class="p-4">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">Lương cơ bản</span>
                        <span>@Model.LuongCoBan.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">Tổng phụ cấp</span>
                        <span>@Model.TongPhuCap.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">Lương làm thêm</span>
                        <span>@Model.LuongLamThem.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">Thưởng</span>
                        <span style="color:#34d399">+@Model.TongThuong.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">Phạt / Khấu trừ</span>
                        <span style="color:#f87171">-@Model.TongPhat.ToString("N0") ₫</span>
                    </div>
                    <hr style="border-color:#2d3148" />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Tổng Gross</span>
                        <span style="color:#60a5fa">@Model.TongThuNhap.ToString("N0") ₫</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khấu trừ -->
        <div class="card-dark">
            <div class="card-header-dark" style="color:#f87171">
                <i class="bi bi-dash-circle"></i> Khấu Trừ
            </div>
            <div class="p-4">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">BHXH (8%)</span>
                        <span style="color:#f87171">-@Model.BaoHiemXaHoi.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">BHYT (1.5%)</span>
                        <span style="color:#f87171">-@Model.BaoHiemYTe.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">BHTN (1%)</span>
                        <span style="color:#f87171">-@Model.BaoHiemThatNghiep.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:#9ca3af">Thuế TNCN</span>
                        <span style="color:#f87171">-@Model.ThueThuNhapCaNhan.ToString("N0") ₫</span>
                    </div>
                    <hr style="border-color:#2d3148" />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Tổng khấu trừ</span>
                        <span style="color:#f87171">
                            -@((Model.BaoHiemXaHoi + Model.BaoHiemYTe + Model.BaoHiemThatNghiep + Model.ThueThuNhapCaNhan).ToString("N0")) ₫
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>