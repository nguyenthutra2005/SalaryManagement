@{
    ViewData["Title"] = "Đăng Nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PayVN - Đăng Nhập</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
            body { background: #0f1117; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; font-family: 'Segoe UI', sans-serif; }
            .login-card { background: #1a1d2e; border: 1px solid #2d3148; border-radius: 16px; padding: 48px 40px; width: 100%; max-width: 420px; }
            .brand-icon { width: 56px; height: 56px; background: #f59e0b; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 24px; color: #1a1d2e; margin: 0 auto 16px; }
            .brand-name { font-size: 24px; font-weight: 700; color: #fff; text-align: center; }
            .brand-sub { font-size: 12px; color: #6b7280; text-align: center; margin-bottom: 32px; }
            .form-label { color: #9ca3af; font-size: 13px; margin-bottom: 6px; }
            .form-control-dark { background: #2d3148; border: 1px solid #3d4468; color: #e2e8f0; border-radius: 8px; padding: 10px 14px; width: 100%; font-size: 14px; }
            .form-control-dark:focus { background: #2d3148; border-color: #f59e0b; color: #e2e8f0; outline: none; box-shadow: 0 0 0 3px rgba(245,158,11,0.15); }
            .btn-login { background: #f59e0b; color: #1a1d2e; font-weight: 700; border: none; border-radius: 8px; padding: 12px; width: 100%; font-size: 15px; margin-top: 8px; cursor: pointer; }
            .btn-login:hover { background: #d97706; }
            .error-box { background: #7f1d1d; border: 1px solid #f87171; color: #f87171; padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand-icon">P</div>
        <div class="brand-name">PayVN</div>
        <div class="brand-sub">HỆ THỐNG QUẢN LÝ LƯƠNG</div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        <form method="post" action="/TaiKhoan/DangNhap">
            <div class="mb-3">
                <label class="form-label">Tên đăng nhập</label>
                <input name="tenDangNhap" type="text" class="form-control-dark" placeholder="Nhập tên đăng nhập" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <input name="matKhau" type="password" class="form-control-dark" placeholder="Nhập mật khẩu" required />
            </div>
            <button type="submit" class="btn-login">
                <i class="bi bi-box-arrow-in-right"></i> Đăng Nhập
            </button>
        </form>
    </div>
</body>
</html>